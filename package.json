{
  "name": "smart-clinic-platform",
  "version": "0.0.0",
  "packageManager": "pnpm@10.17.1",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev -w @workspace/api-server",
    "dev:frontend": "npm run dev -w @workspace/smart-clinic",
    "build": "npm run typecheck && npm run build -w @workspace/api-server && npm run build -w @workspace/smart-clinic",
    "start": "npm run start -w @workspace/api-server",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck -w @workspace/api-server && npm run typecheck -w @workspace/smart-clinic",
    "db:push": "npm run push -w @workspace/db",
    "db:push-force": "npm run push-force -w @workspace/db"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {},
  "workspaces": [
    "artifacts/api-server",
    "artifacts/smart-clinic",
    "lib/api-client-react",
    "lib/api-zod",
    "lib/db"
  ]
}
