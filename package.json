{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev -w @workspace/api-server",
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "start": "npm run start -w @workspace/api-server",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present"
  },
  "private": true,
  "devDependencies": {
    "pg": "^8.21.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-kit": "0.31.9",
    "drizzle-orm": "^0.45.2"
  },
  "workspaces": [
    "artifacts/api-server",
    "artifacts/smart-clinic",
    "artifacts/mockup-sandbox",
    "lib/api-client-react",
    "lib/api-spec",
    "lib/api-zod",
    "lib/db",
    "scripts"
  ]
}
